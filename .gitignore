# ──────────────────────────────────────────────
# SharedParkingCalculator  —  Python .gitignore
# ──────────────────────────────────────────────

# ── Byte-compiled / optimised / DLL files ────
__pycache__/
*.py[cod]
*$py.class

# ── Distribution / packaging ─────────────────
build/
dist/
*.egg-info/
*.egg
*.whl

# ── Virtual environments ─────────────────────
# The project uses an external venv at C:\Envs\SharedParkingCalculator
# but ignore any local venvs that might be created accidentally
.venv/
venv/
env/
ENV/

# ── uv / pip artefacts ───────────────────────
# Keep uv.lock in the repo for deterministic installs
# but ignore caches
.uv/
pip-log.txt
pip-delete-this-directory.txt

# ── IDE / editor ─────────────────────────────
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.swp
*.swo
*~

# ── OS generated ─────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
.DS_Store?
._*

# ── Testing / coverage ──────────────────────
.pytest_cache/
.coverage
htmlcov/
*.cover

# ── Jupyter Notebooks ───────────────────────
.ipynb_checkpoints/

# ── mypy / type-checking ────────────────────
.mypy_cache/
.dmypy.json
dmypy.json

# ── Output artefacts ────────────────────────
# Ignore generated Excel files in Outputs/
Outputs/*.xlsx
